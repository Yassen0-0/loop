{
  "expo": {
    "name": "Loop",
    "slug": "loop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "loop",
    "android": {
      "package": "com.loop.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loop.app",
      "buildNumber": "1"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-sqlite", "expo-localization"],
    "extra": {
      "environment": "development",
      "databaseName": "loop.db"
    }
  }
}
